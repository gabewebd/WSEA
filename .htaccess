RewriteEngine On

# --- Force NON-WWW (Redirects www.danonos.com -> danonos.com) ---
RewriteCond %{HTTP_HOST} ^www\.danonos\.com [NC]
RewriteRule ^(.*)$ https://danonos.com/$1 [L,R=301]

# Force redirect from old query string to new pretty URL
RewriteCond %{QUERY_STRING} ^slug=([a-zA-Z0-9_-]+)$
RewriteRule ^single-blog\.php$ /blog/%1? [R=301,L]
# ---------------------------------------------------------------------------

# 1. Force remove trailing slash (e.g. danonos.com/about/ -> danonos.com/about)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# 2. Redirect "home" (or "home.php") to the main root URL "/"
RewriteRule ^home(\.php)?/?$ / [R=301,L]

# 3. Remove "index.php" or "index" forcing it to just "/"
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.*)index(\.php)?\ HTTP/
RewriteRule ^(.*)index(\.php)?$ /$1 [R=301,L]

# 4. Redirect all OTHER .php requests to the clean URL (e.g. about.php -> about)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php\ HTTP/
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# 5. Map the clean URL back to the .php file internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# 6. Handle 404 errors
ErrorDocument 404 /404.php

# 7. Pretty URLs for Blogs (e.g., danonos.com/blog/my-post)
RewriteRule ^blog/([a-zA-Z0-9_-]+)$ single-blog.php?slug=$1 [L,QSA]
