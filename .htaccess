RewriteEngine On
RewriteBase /

# 0. Allow direct access to robots.txt and sitemap.xml without routing
RewriteRule ^robots\.txt$ - [L]
RewriteRule ^sitemap\.xml$ - [L]

# 1. IGNORE ADMIN FOLDER
# This prevents the pretty URL rules from breaking the admin login and dashboard
RewriteRule ^admin/ - [L]

# 2. REDIRECT OLD HYPHENATED APOSTROPHES IN PRETTY URLS
# Fixes: danonos.com/blog/danono-s-donuts -> danonos.com/blog/danonos-donuts
RewriteRule ^blog/(.*)-s-(.*)$ /blog/$1s-$2 [R=301,L]

# 3. Force NON-WWW (Redirects www.danonos.com -> danonos.com)
RewriteCond %{HTTP_HOST} ^www\.danonos\.com [NC]
RewriteRule ^(.*)$ https://danonos.com/$1 [L,R=301]

# 4. Redirect "home" or "index" to root "/"
RewriteRule ^home(\.php)?$ / [R=301,L]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*index(\.php)?\ HTTP/
RewriteRule ^(.*)index(\.php)?$ /$1 [R=301,L]

# 5. REDIRECT OLD QUERY STRINGS AND FIX HYPHENATED APOSTROPHES
# This handles old URLs like single-blog.php?slug=danono-s-donuts and redirects to /blog/danonos-donuts
RewriteCond %{QUERY_STRING} ^slug=(.*)-s-(.*)$
RewriteRule ^single-blog\.php$ /blog/%1s-%2? [R=301,L]

# Standard redirect for ?slug= (if no hyphenated apostrophe is present)
RewriteCond %{QUERY_STRING} ^slug=([a-zA-Z0-9_-]+)$
RewriteRule ^single-blog\.php$ /blog/%1? [R=301,L]

# 6. Blog Pretty URLs: Internal Mapping
# Maps danonos.com/blog/my-post internally to single-blog.php?slug=my-post
RewriteRule ^blog/([a-zA-Z0-9_-]+)/?$ single-blog.php?slug=$1 [L,QSA]

# 7. Remove .php extension from URL (External Redirect)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php\ HTTP/
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# 8. Map Clean URL back to .php internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# 9. Force remove trailing slash (except for directories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# 10. Handle 404 errors
ErrorDocument 404 /404.php

# 11. Performance: Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images (1 Year)
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # Fonts (1 Year)
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    
    # CSS & JS (1 Month)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    ExpiresDefault "access plus 2 days"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(webp|png|jpe?g|ico|svg|woff2?|ttf|css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>